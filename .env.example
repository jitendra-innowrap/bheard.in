# =========================
# App Environment Template
# =========================
# Copy this file to `.env` (local) or set these in your host panel.

# MySQL connection string for Prisma
# Format:
# mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@127.0.0.1:3306/bheard"

# Admin panel login credentials (simple password gate)
ADMIN_EMAIL="admin@bheard.in"
ADMIN_PASSWORD="change-this-to-a-strong-password"

# Random secret used to sign admin session cookies
# Use a long random string (32+ chars recommended)
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret-value"

