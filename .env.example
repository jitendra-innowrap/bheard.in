# =========================
# App Environment Template
# =========================
# Copy this file to `.env` (local) or set these in your host panel.

# MongoDB connection string (Mongoose + Prisma)
# Use database name in the path (e.g. /bheard). If mongodb+srv fails on Windows
# with querySrv ECONNREFUSED, use the standard mongodb:// URI from Atlas Connect.
DATABASE_URL=mongodb+srv://admin:WKrWbSC62VvZC9zO@cluster0.8yhe66h.mongodb.net/bheard?retryWrites=true&w=majority&appName=Cluster0

# Admin panel login credentials (simple password gate)
ADMIN_EMAIL=admin-bheard
ADMIN_PASSWORD=WKrWbSC62VvZC9zO

# Random secret used to sign admin session cookies
# Use a long random string (32+ chars recommended)
ADMIN_SESSION_SECRET="bheard-admin-session-secret"

# Form notification recipients (comma-separated). Required for email alerts.
# Lead form internal notifications only (career applications are database-only)
LEAD_NOTIFICATION_TO=team@example.com
# Fallback if LEAD_NOTIFICATION_TO is unset
# FORM_NOTIFICATION_TO=team@example.com

# SMTP (preferred when set — e.g. Gmail, SendGrid SMTP, Microsoft 365 SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=BHEARD

# Microsoft Graph (used when SMTP_HOST is not set)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SENDER_EMAIL=
AZURE_SENDER_NAME=BHEARD

# Public site URL (logo in notification emails)
NEXT_PUBLIC_SITE_URL=https://bheard.in

