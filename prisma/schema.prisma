generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  slug        String    @unique
  title       String
  subtitle    String?
  showAuthorDetails Boolean @default(true)
  author      String?
  authorImage String?
  excerpt     String
  thumbnailUrl String?
  thumbnailAlt String?
  content     String
  category    String
  readTime    Int
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Career {
  id            String               @id @default(auto()) @map("_id") @db.ObjectId
  slug          String               @unique
  title         String
  department    String
  type          String
  location      String
  description   String
  active        Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  applications  CareerApplication[]
}

model CareerApplication {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  careerId  String? @db.ObjectId
  career    Career? @relation(fields: [careerId], references: [id], onDelete: SetNull)

  careerSlug  String
  careerTitle String

  fullName          String
  email             String
  phone             String
  city              String
  yearsExperience   String
  roleTitleApplied  String
  currentCompany    String?
  portfolioUrl      String?
  linkedInUrl       String?
  expectedSalary    String?
  noticePeriod      String
  coverLetter       String
  referralSource    String?
  workAuthorization String?

  resumeFileName   String
  resumeStoredPath String
  resumeMime       String
  resumeSize       Int

  createdAt DateTime @default(now())

  @@index([careerId])
  @@index([createdAt])
}

model SuccessStory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  slug           String   @unique
  title          String
  industry       String
  listImage      String?
  heroImage      String?
  caseData       Json?
  summary        String
  about          String
  challenge      String
  solution       String
  results        String
  contactCta     String
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  filename  String
  path      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}

model Page {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model ContactLead {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName   String
  email      String
  phone      String?
  company    String?
  message    String
  sourcePage String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
  @@index([email])
}
