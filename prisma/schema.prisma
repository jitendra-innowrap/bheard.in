generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  category    String
  readTime    Int
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Career {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  department  String
  type        String
  location    String
  description String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SuccessStory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  slug           String   @unique
  title          String
  industry       String
  summary        String
  about          String
  challenge      String
  solution       String
  results        String
  contactCta     String
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  filename  String
  path      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}
